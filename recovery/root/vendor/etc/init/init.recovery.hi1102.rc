# init.recovery.hi1102.rc
# Honor 10 Lite (HRY-LX1)
# HiSilicon Hi1102 Wi-Fi bring-up for recovery
# Copied from vendor/etc/init/init.recovery.hi1102.rc

on init
    # Load Hi1102 Wi-Fi kernel module
    insmod /vendor/lib/modules/hisi_wifi.ko

on property:wlan.driver.status=ok
    # Wi-Fi firmware path for hi1102
    write /sys/module/hisi_wifi/parameters/firmware_path "/vendor/firmware/wifi/hi1102"

service wpa_supplicant /vendor/bin/hw/wpa_supplicant \
    -O/data/vendor/wifi/wpa/sockets \
    -puse_p2p_group_interface=1 \
    -g@android:wpa_wlan0
    interface android.hardware.wifi.supplicant@1.0::ISupplicant default
    interface android.hardware.wifi.supplicant@1.1::ISupplicant default
    class main
    socket wpa_wlan0 dgram 660 wifi wifi
    disabled
    oneshot
